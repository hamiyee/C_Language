{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build Debug version",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}/build/Debug/outDebug",
                "-fexec-charset=GBK", //增加后中文不显示乱码
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Generated build task for Debug version",
            "dependsOn": [
                "createBuildDir"
            ]
        },
        {
            "label": "createBuildDir",
            "type": "shell",
            "command": "mkdir",
            "args": [
                "-p",
                "${workspaceFolder}/build/Debug"
            ],
            "problemMatcher": []
        }
    ]
}